#include "stm32f401xe.h"

#define ENCODER_PPR 1320.0f
#define TS          0.01f

volatile int g_left_count = 0;
volatile int g_right_count = 0;

volatile int g_left_delta = 0;
volatile int g_right_delta = 0;

volatile int g_left_dir = 0;
volatile int g_right_dir = 0;

volatile int g_left_rpm_x10 = 0;
volatile int g_right_rpm_x10 = 0;

volatile int g_speed_error_x10 = 0;
volatile int g_sample_flag = 0;

void Encoder_Init(void);
void TIM5_10ms_Init(void);

int main(void)
{
    int left_old = 0;
    int right_old = 0;

    float left_rpm_filter = 0;
    float right_rpm_filter = 0;

    Encoder_Init();
    TIM5_10ms_Init();

    while (1)
    {
        if (g_sample_flag)
        {
            g_sample_flag = 0;

            int left_now = (int16_t)TIM2->CNT;
            int right_now = (int16_t)TIM4->CNT;

            int left_delta = left_now - left_old;
            int right_delta = right_now - right_old;

            left_old = left_now;
            right_old = right_now;

            float left_rpm = ((float)left_delta * 60.0f) / (ENCODER_PPR * TS);
            float right_rpm = ((float)right_delta * 60.0f) / (ENCODER_PPR * TS);

            left_rpm_filter = 0.7f * left_rpm_filter + 0.3f * left_rpm;
            right_rpm_filter = 0.7f * right_rpm_filter + 0.3f * right_rpm;

            g_left_count = left_now;
            g_right_count = right_now;

            g_left_delta = left_delta;
            g_right_delta = right_delta;

            g_left_dir = (left_delta > 0) - (left_delta < 0);
            g_right_dir = (right_delta > 0) - (right_delta < 0);

            g_left_rpm_x10 = (int)(left_rpm_filter * 10.0f);
            g_right_rpm_x10 = (int)(right_rpm_filter * 10.0f);

            g_speed_error_x10 = g_left_rpm_x10 - g_right_rpm_x10;
        }
    }
}

void Encoder_Init(void)
{
    RCC->AHB1ENR |= (1 << 0);   // GPIOA clock
    RCC->AHB1ENR |= (1 << 1);   // GPIOB clock

    RCC->APB1ENR |= (1 << 0);   // TIM2 clock
    RCC->APB1ENR |= (1 << 2);   // TIM4 clock

    // PA0, PA1 alternate function
    GPIOA->MODER &= ~((3 << 0) | (3 << 2));
    GPIOA->MODER |=  ((2 << 0) | (2 << 2));

    // PA0, PA1 = AF1 = TIM2
    GPIOA->AFR[0] &= ~((15 << 0) | (15 << 4));
    GPIOA->AFR[0] |=  ((1 << 0) | (1 << 4));

    // Pull-up PA0, PA1
    GPIOA->PUPDR &= ~((3 << 0) | (3 << 2));
    GPIOA->PUPDR |=  ((1 << 0) | (1 << 2));

    // PB6, PB7 alternate function
    GPIOB->MODER &= ~((3 << 12) | (3 << 14));
    GPIOB->MODER |=  ((2 << 12) | (2 << 14));

    // PB6, PB7 = AF2 = TIM4
    GPIOB->AFR[0] &= ~((15 << 24) | (15 << 28));
    GPIOB->AFR[0] |=  ((2 << 24) | (2 << 28));

    // Pull-up PB6, PB7
    GPIOB->PUPDR &= ~((3 << 12) | (3 << 14));
    GPIOB->PUPDR |=  ((1 << 12) | (1 << 14));

    // TIM2 encoder mode 3
    TIM2->CR1 = 0;
    TIM2->SMCR = 0;
    TIM2->CCMR1 = 0;
    TIM2->CCER = 0;

    TIM2->SMCR |= (3 << 0);
    TIM2->CCMR1 |= (1 << 0) | (1 << 8);
    TIM2->CCMR1 |= (3 << 4) | (3 << 12);
    TIM2->ARR = 0xFFFF;
    TIM2->CNT = 0;
    TIM2->CR1 |= (1 << 0);

    // TIM4 encoder mode 3
    TIM4->CR1 = 0;
    TIM4->SMCR = 0;
    TIM4->CCMR1 = 0;
    TIM4->CCER = 0;

    TIM4->SMCR |= (3 << 0);
    TIM4->CCMR1 |= (1 << 0) | (1 << 8);
    TIM4->CCMR1 |= (3 << 4) | (3 << 12);
    TIM4->ARR = 0xFFFF;
    TIM4->CNT = 0;
    TIM4->CR1 |= (1 << 0);
}

void TIM5_10ms_Init(void)
{
    RCC->APB1ENR |= (1 << 3);   // TIM5 clock

    TIM5->PSC = 1600 - 1;
    TIM5->ARR = 100 - 1;
    TIM5->CNT = 0;

    TIM5->DIER |= (1 << 0);
    NVIC_EnableIRQ(TIM5_IRQn);

    TIM5->CR1 |= (1 << 0);
}

void TIM5_IRQHandler(void)
{
    if (TIM5->SR & (1 << 0))
    {
        TIM5->SR &= ~(1 << 0);
        g_sample_flag = 1;
    }
}

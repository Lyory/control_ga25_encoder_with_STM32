#include "stm32f401xe.h"
#include <stdint.h>

/* ================= BIEN SWV ================= */

volatile int g_pwm = 0;

volatile int g_left_count = 0;
volatile int g_right_count = 0;

volatile int g_left_delta = 0;
volatile int g_right_delta = 0;

volatile int g_left_rpm_x10 = 0;
volatile int g_right_rpm_x10 = 0;

volatile int g_speed_error_x10 = 0;
volatile int g_position_error = 0;

volatile int g_sample_count = 0;
volatile int g_pwm_index = 0;

/* ================= THONG SO ================= */

#define ENCODER_PPR      1320
#define DELTA_LIMIT      300
#define SAMPLE_PER_PWM   500     // 500 * 10ms = 5s
#define PWM_LEVEL_COUNT  4

/*
    Bat dau tu 500 vi PWM thap lam 2 banh khoi dong khong dong thoi.
*/
int pwm_table[PWM_LEVEL_COUNT] = {500, 600, 700, 800};

/*
    Doi dau neu xe chay tien ma count bi am.
*/
int left_sign = 1;
int right_sign = 1;

/* ================= BIEN NOI BO ================= */

volatile uint16_t left_now = 0;
volatile uint16_t left_old = 0;

volatile uint16_t right_now = 0;
volatile uint16_t right_old = 0;

volatile int left_total = 0;
volatile int right_total = 0;

/* ================= KHAI BAO HAM ================= */

void Motor_GPIO_Init(void);
void TIM3_PWM_Init(void);
void Encoder_Init(void);
void TIM5_10ms_Init(void);

void Motor_Forward(void);
void Motor_SetPWM(int pwm);

/* ================= MAIN ================= */

int main(void)
{
    Motor_GPIO_Init();
    TIM3_PWM_Init();
    Encoder_Init();
    TIM5_10ms_Init();

    Motor_Forward();
    Motor_SetPWM(pwm_table[0]);

    while (1)
    {
        /*
            Tat ca viec lay mau encoder duoc lam trong TIM5_IRQHandler.
        */
    }
}

/* ================= GPIO MOTOR + PWM PIN ================= */

void Motor_GPIO_Init(void)
{
    /*
        PA6 = TIM3_CH1
        PA7 = TIM3_CH2

        PC0, PC1 = chieu motor trai
        PC2, PC3 = chieu motor phai
    */

    RCC->AHB1ENR |= (1 << 0);   // GPIOA clock
    RCC->AHB1ENR |= (1 << 2);   // GPIOC clock

    // PC0-PC3 output
    GPIOC->MODER &= ~((3 << 0) | (3 << 2) | (3 << 4) | (3 << 6));
    GPIOC->MODER |=  ((1 << 0) | (1 << 2) | (1 << 4) | (1 << 6));

    // PA6, PA7 alternate function
    GPIOA->MODER &= ~((3 << 12) | (3 << 14));
    GPIOA->MODER |=  ((2 << 12) | (2 << 14));

    // GPIOA_AFRL: PA6, PA7 = AF2 = TIM3
    GPIOA->AFR[0] &= ~((15 << 24) | (15 << 28));
    GPIOA->AFR[0] |=  ((2 << 24) | (2 << 28));
}

/* ================= TIM3 PWM ================= */

void TIM3_PWM_Init(void)
{
    RCC->APB1ENR |= (1 << 1);   // TIM3 clock

    /*
        Clock = 16 MHz
        PSC = 16 - 1   -> timer tick = 1 MHz
        ARR = 1000 - 1 -> PWM = 1 kHz
    */
    TIM3->PSC = 16 - 1;
    TIM3->ARR = 1000 - 1;

    TIM3->CCR1 = 0;
    TIM3->CCR2 = 0;

    // CH1, CH2 PWM mode 1
    TIM3->CCMR1 &= ~((7 << 4) | (7 << 12));
    TIM3->CCMR1 |=  ((6 << 4) | (6 << 12));

    // Enable CH1, CH2
    TIM3->CCER |= (1 << 0) | (1 << 4);

    // Start TIM3
    TIM3->CR1 |= (1 << 0);
}

/* ================= ENCODER TIM2 + TIM4 ================= */

void Encoder_Init(void)
{
    /*
        TIM2:
        PA0 = TIM2_CH1
        PA1 = TIM2_CH2

        TIM4:
        PB6 = TIM4_CH1
        PB7 = TIM4_CH2
    */

    RCC->AHB1ENR |= (1 << 0);   // GPIOA clock
    RCC->AHB1ENR |= (1 << 1);   // GPIOB clock

    RCC->APB1ENR |= (1 << 0);   // TIM2 clock
    RCC->APB1ENR |= (1 << 2);   // TIM4 clock

    /* PA0, PA1 = AF1 TIM2 */
    GPIOA->MODER &= ~((3 << 0) | (3 << 2));
    GPIOA->MODER |=  ((2 << 0) | (2 << 2));

    GPIOA->AFR[0] &= ~((15 << 0) | (15 << 4));
    GPIOA->AFR[0] |=  ((1 << 0) | (1 << 4));

    GPIOA->PUPDR &= ~((3 << 0) | (3 << 2));
    GPIOA->PUPDR |=  ((1 << 0) | (1 << 2));

    /* PB6, PB7 = AF2 TIM4 */
    GPIOB->MODER &= ~((3 << 12) | (3 << 14));
    GPIOB->MODER |=  ((2 << 12) | (2 << 14));

    GPIOB->AFR[0] &= ~((15 << 24) | (15 << 28));
    GPIOB->AFR[0] |=  ((2 << 24) | (2 << 28));

    GPIOB->PUPDR &= ~((3 << 12) | (3 << 14));
    GPIOB->PUPDR |=  ((1 << 12) | (1 << 14));

    /* TIM2 encoder mode 3 */
    TIM2->CR1 = 0;
    TIM2->SMCR = 0;
    TIM2->CCMR1 = 0;
    TIM2->CCER = 0;

    TIM2->SMCR |= (3 << 0);                 // SMS = 011
    TIM2->CCMR1 |= (1 << 0) | (1 << 8);     // CC1S = 01, CC2S = 01
    TIM2->CCMR1 |= (3 << 4) | (3 << 12);    // input filter

    TIM2->ARR = 0xFFFF;
    TIM2->CNT = 0;
    TIM2->CR1 |= (1 << 0);

    /* TIM4 encoder mode 3 */
    TIM4->CR1 = 0;
    TIM4->SMCR = 0;
    TIM4->CCMR1 = 0;
    TIM4->CCER = 0;

    TIM4->SMCR |= (3 << 0);
    TIM4->CCMR1 |= (1 << 0) | (1 << 8);
    TIM4->CCMR1 |= (3 << 4) | (3 << 12);

    TIM4->ARR = 0xFFFF;
    TIM4->CNT = 0;
    TIM4->CR1 |= (1 << 0);
}

/* ================= TIM5 10ms ================= */

void TIM5_10ms_Init(void)
{
    RCC->APB1ENR |= (1 << 3);   // TIM5 clock

    /*
        Clock = 16 MHz
        PSC = 1600 - 1 -> 10 kHz
        ARR = 100 - 1  -> 10 ms
    */
    TIM5->PSC = 1600 - 1;
    TIM5->ARR = 100 - 1;
    TIM5->CNT = 0;

    TIM5->DIER |= (1 << 0);     // update interrupt enable
    NVIC_EnableIRQ(TIM5_IRQn);

    TIM5->CR1 |= (1 << 0);      // start TIM5
}

/* ================= TIM5 INTERRUPT ================= */

void TIM5_IRQHandler(void)
{
    if (TIM5->SR & (1 << 0))
    {
        TIM5->SR &= ~(1 << 0);

        /* Doi muc PWM moi 5s */
        g_sample_count++;

        if (g_sample_count >= SAMPLE_PER_PWM)
        {
            g_sample_count = 0;

            g_pwm_index++;

            if (g_pwm_index >= PWM_LEVEL_COUNT)
            {
                g_pwm_index = 0;
            }

            Motor_SetPWM(pwm_table[g_pwm_index]);
        }

        /* Doc encoder */
        left_now = TIM2->CNT;
        right_now = TIM4->CNT;

        g_left_delta = left_sign * (int16_t)(left_now - left_old);
        g_right_delta = right_sign * (int16_t)(right_now - right_old);

        left_old = left_now;
        right_old = right_now;

        /* Loc delta bat thuong */
        if (g_left_delta > DELTA_LIMIT || g_left_delta < -DELTA_LIMIT)
        {
            g_left_delta = 0;
        }

        if (g_right_delta > DELTA_LIMIT || g_right_delta < -DELTA_LIMIT)
        {
            g_right_delta = 0;
        }

        /* Tinh count tich luy */
        left_total += g_left_delta;
        right_total += g_right_delta;

        g_left_count = left_total;
        g_right_count = right_total;

        /* Tinh RPM x10 */
        g_left_rpm_x10 = g_left_delta * 60000 / ENCODER_PPR;
        g_right_rpm_x10 = g_right_delta * 60000 / ENCODER_PPR;

        /* Tinh sai so */
        g_speed_error_x10 = g_left_rpm_x10 - g_right_rpm_x10;
        g_position_error = g_left_count - g_right_count;
    }
}

/* ================= MOTOR ================= */

void Motor_Forward(void)
{
    // Motor trai: PC0 = 1, PC1 = 0
    GPIOC->BSRR = (1 << 0);
    GPIOC->BSRR = (1 << (1 + 16));

    // Motor phai: PC2 = 1, PC3 = 0
    GPIOC->BSRR = (1 << 2);
    GPIOC->BSRR = (1 << (3 + 16));
}

void Motor_SetPWM(int pwm)
{
    if (pwm < 0)
    {
        pwm = 0;
    }

    if (pwm > 999)
    {
        pwm = 999;
    }

    /*
        Khong co bu PWM:
        hai banh luon nhan cung mot gia tri PWM.
    */
    TIM3->CCR1 = pwm;
    TIM3->CCR2 = pwm;

    g_pwm = pwm;
}
